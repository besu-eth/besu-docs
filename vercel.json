{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Link",
          "value": "</sitemap.xml>; rel=\"sitemap\"; type=\"application/xml\", </llms.txt>; rel=\"describedby\"; type=\"text/plain\", </llms-full.txt>; rel=\"describedby\"; type=\"text/plain\""
        }
      ]
    },
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "accept",
          "value": ".*text/markdown.*"
        }
      ],
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/markdown; charset=utf-8"
        }
      ]
    },
    {
      "source": "/(.*)\\.md",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/markdown; charset=utf-8"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/en/latest", "destination": "/", "permanent": true },
    { "source": "/en/latest/", "destination": "/", "permanent": true },
    {
      "source": "/en/latest/:match(.*)",
      "destination": "/:match(.*)",
      "permanent": true
    },
    { "source": "/en/stable", "destination": "/", "permanent": true },
    { "source": "/en/stable/", "destination": "/", "permanent": true },
    {
      "source": "/en/stable/:match(.*)",
      "destination": "/:match(.*)",
      "permanent": true
    },
    { "source": "/en/development", "destination": "/", "permanent": true },
    { "source": "/en/development/", "destination": "/", "permanent": true },
    {
      "source": "/en/development/:match(.*)",
      "destination": "/:match(.*)",
      "permanent": true
    },
    {
      "source": "/:version(\\d+\\.\\d+\\.\\d+)/:match(.*)",
      "destination": "/:match",
      "permanent": true
    },
    {
      "source": "/private-networks/how-to/configure/consensus/clique/",
      "destination": "/private-networks/how-to/configure/consensus/"
    },
    {
      "source": "/private-networks/tutorials/clique/",
      "destination": "/private-networks/tutorials/"
    },
    {
      "source": "/private-networks/tutorials/ethash/",
      "destination": "/private-networks/tutorials/"
    },
    {
      "source": "/public-networks/concepts/plugins/",
      "destination": "/plugins/"
    },
    {
      "source": "/private-networks/concepts/permissioning/plugin/",
      "destination": "/plugins/features/permissioning-peers/"
    },
    {
      "source": "/public-networks/reference/plugin-api-interfaces/",
      "destination": "/plugins/"
    },
    {
      "source": "/public-networks/reference/api/objects/",
      "destination": "/public-networks/reference/api/eth/"
    },
    {
      "source": "/public-networks/reference/engine-api/objects/",
      "destination": "/public-networks/reference/engine-api/"
    },
    {
      "source": "/public-networks/reference/trace-types/",
      "destination": "/public-networks/reference/api/trace/"
    },
    {
      "source": "/public-networks/reference/cli/options/",
      "destination": "/public-networks/reference/options/"
    },
    {
      "source": "/public-networks/reference/cli/subcommands/",
      "destination": "/public-networks/reference/subcommands/"
    },
    {
      "source": "/private-networks/reference/cli/options/",
      "destination": "/private-networks/reference/options/"
    },
    {
      "source": "/private-networks/reference/cli/subcommands/",
      "destination": "/private-networks/reference/subcommands/"
    },
    {
      "source": "/public-networks/how-to/configuration-file/",
      "destination": "/public-networks/how-to/configure-besu/"
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "accept",
          "value": ".*text/markdown.*"
        }
      ],
      "destination": "/index.md"
    },
    {
      "source": "/:path+",
      "has": [
        {
          "type": "header",
          "key": "accept",
          "value": ".*text/markdown.*"
        }
      ],
      "destination": "/:path+.md"
    }
  ]
}
